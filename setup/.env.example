# ============================================================
# Real Estate Argentina Analytics — Variables de Entorno
# ============================================================
# 1. Copiá este archivo: cp .env.example .env
# 2. Completá los valores reales en .env
# 3. NUNCA subas .env a GitHub (ya está en .gitignore)
# ============================================================

# — Kaggle API (obtenelo en kaggle.com → Settings → API) —
KAGGLE_USERNAME=tu_usuario_kaggle
KAGGLE_KEY=tu_api_key_kaggle

# — Rutas del proyecto —
PROJECT_DIR=.
DUCKDB_PATH=./data/real_estate.duckdb
RAW_DATA_DIR=./data/raw

# — dbt —
DBT_PROJECT_DIR=./dbt_realestate
DBT_PROFILES_DIR=./dbt_realestate
